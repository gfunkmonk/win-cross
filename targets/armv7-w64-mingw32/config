CT_CONFIG_VERSION="4"
CT_EXPERIMENTAL=y
CT_PREFIX_DIR="/opt/x-tools/${CT_TARGET}"
# CT_LOG_PROGRESS_BAR is not set
CT_ARCH_ARM=y
CT_ARCH_ARCH="armv7-a"
CT_ARCH_SUFFIX="v7"
CT_ARCH_FPU="vfpv3-d16"
CT_ARCH_FLOAT_HW=y
# CT_ARCH_ARM_EABI is not set
CT_TARGET_VENDOR="w64"
CT_KERNEL_WINDOWS=y
CT_BINUTILS_PLUGINS=y
CT_MINGW_DIRECTX=y
CT_MINGW_DDK=y
# CT_THREADS_POSIX is not set
CT_THREADS_WIN32=y
CT_LIBC_MINGW_W64_POSIX_PTHREADS=y
CT_CC_LANG_CXX=y
# CT_CC_LANG_FORTRAN is not set
# CT_LINKER_MOLD is not set
# CT_BINUTILS_LINKER_LD_GOLD is not set
# CT_BINUTILS_GOLD_THREADS is not set
# CT_BINUTILS_LD_WRAPPER is not set
CT_BINUTILS_LINKER_LD_BFD=y
CT_GCC_V_15=y
CT_BINUTILS_V_2_46=y
CT_MINGW_W64_V_14_0=y
CT_LIBC_MINGW_W64_CRT_EXTRA_CONFIG_ARRAY="--disable-lib32 --disable-lib64"
CT_WANTS_STATIC_LINK=y
CT_WANTS_STATIC_LINK_CXX=y
CT_STATIC_TOOLCHAIN=y
